TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# ID вашего Telegram (можно узнать у @userinfobot), через запятую если админов несколько
ADMIN_CHAT_IDS=962443492

# Канал, на который нужно подписаться (без @). Бот должен быть админом канала.
CHANNEL_USERNAME=energy_temnikovo

# Веб-панель за Nginx: приложение слушает 5001, Nginx принимает 80/443 и проксирует на 127.0.0.1:5001.
WEB_PORT=5001
WEB_PASSWORD=ваш_надёжный_пароль
WEB_SECRET_KEY=замените_на_длинную_случайную_строку
WEB_HTTPS=true

# Публичный HTTPS-адрес для инлайн-PDF (поддомен того же сервера). Пример: https://bot.sebog1.ru
PUBLIC_BASE_URL=

IMAP_EMAIL=your.gmail.login@gmail.com
IMAP_PASSWORD=your_app_password_here
ALLOWED_SENDER=vikastruk26@yandex.ru

